<Window x:Class="Group4338._4338_Khayrullina"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="4338_Khayrullina" 
        Height="400" 
        Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
            <TextBlock Text="Информация об авторе" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Margin="10"/>
            <TextBlock Text="Фамилия: Хайруллина" 
                       FontSize="14" 
                       Margin="5"/>
            <TextBlock Text="Имя: Ландыш" 
                       FontSize="14" 
                       Margin="5"/>
            <TextBlock Text="Возраст: 18" 
                       FontSize="14" 
                       Margin="5"/>
            <TextBlock Text="Группа: 4338" 
                       FontSize="14" 
                       Margin="5"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Импорт данных" 
                    Click="ImportButton_Click"
                    Width="150" 
                    Height="40"
                    Margin="10"
                    Background="LightGreen"/>

            <Button Content="Экспорт в Excel" 
                    Click="ExportButton_Click"
                    Width="150" 
                    Height="40"
                    Margin="10"
                    Background="LightBlue"/>
        </StackPanel>
    </Grid>
</Window>